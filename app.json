{
  "expo": {
    "name": "플리로그",
    "slug": "playlist",
    "scheme": "com.playlist.app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#f4ecdd",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4ecdd"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.playlist.app",
      "backgroundColor": "#f4ecdd",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "녹음 기능을 사용하기 위해 마이크 접근 권한이 필요합니다.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.playlist.app",
      "backgroundColor": "#f4ecdd",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4ecdd"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "녹음 기능을 사용하기 위해 마이크 접근 권한이 필요합니다.",
          "enableBackgroundAudio": true
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "85417100-960a-47f3-9b07-5af25be39e7a"
      }
    }
  }
}
